# Supabase (source) — copy from pch-api/.env
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<...>
SUPABASE_SECRET_KEY=sb_secret_<...>

# Sanity (target) — write token with Editor role
# Manage → API → Tokens → Add token → role: Editor
SANITY_PROJECT_ID=<your-project-id>
SANITY_DATASET=production
SANITY_API_VERSION=2024-10-01
SANITY_WRITE_TOKEN=<your-sanity-write-token>

# Local backup dir (relative to scripts/migrate)
BACKUP_DIR=./backups
